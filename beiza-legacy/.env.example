# ──────────────────────────────────────────────────────────
# Stories From the Sun — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# ──────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare R2 (audio storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sun-stories-dev

# Stripe (use test keys for local dev)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_PREMIUM_MONTHLY=price_
STRIPE_PRICE_PREMIUM_ANNUAL=price_

# Anthropic (Claude Haiku — Sun Assistant AI, Pro plan only)
ANTHROPIC_API_KEY=sk-ant-

# Resend (transactional email)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@sunstories.app

# App URLs
APP_URL=http://localhost:8081
MARKETING_URL=http://localhost:3002
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_URL=http://localhost:3002

# Monitoring (optional for local dev)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# App version (set by CI in production)
APP_VERSION=0.1.0
NODE_ENV=development
